# Application
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
FRONTEND_ORIGIN=http://127.0.0.1:3000

# Supabase development project only. Obtain local values with:
# npm run supabase:status -- -o env
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Legacy development projects may provide a service-role key instead.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_RAW_BUCKET=dst-wiki-raw
SUPABASE_SNAPSHOT_BUCKET=dst-corpus-snapshots
SUPABASE_EVAL_BUCKET=dst-evaluation-reports

# The initial vector schema is fixed at 1024 dimensions.
EMBEDDING_DIMENSIONS=1024

# This is intentionally public: the browser calls FastAPI, never Supabase.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
