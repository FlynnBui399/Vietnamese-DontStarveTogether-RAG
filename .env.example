# Application
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
FRONTEND_ORIGIN=http://127.0.0.1:3000

# Supabase development project only. Obtain local values with:
# npm run supabase:status -- -o env
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Legacy development projects may provide a service-role key instead.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_RAW_BUCKET=dst-wiki-raw
SUPABASE_SNAPSHOT_BUCKET=dst-corpus-snapshots
SUPABASE_EVAL_BUCKET=dst-evaluation-reports

# MediaWiki ingestion. Keep requests serial and identify this project honestly.
WIKI_BASE_URL=https://dontstarve.wiki.gg
WIKI_API_URL=https://dontstarve.wiki.gg/api.php
WIKI_USER_AGENT=DSTVietnameseAssistant/0.2 (https://github.com/FlynnBui399/Vietnamese-DontStarveTogether-RAG)
WIKI_REQUEST_DELAY_MS=500
WIKI_MAX_CONCURRENCY=1
WIKI_REQUEST_TIMEOUT_SECONDS=20
WIKI_MAX_RETRIES=3
WIKI_CACHE_DIR=data/cache/mediawiki
WIKI_CACHE_TTL_SECONDS=3600

# The initial vector schema is fixed at 1024 dimensions.
EMBEDDING_DIMENSIONS=1024
EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://127.0.0.1:11434
EMBEDDING_MODEL=bge-m3
EMBEDDING_MODEL_REVISION=unversioned
EMBEDDING_BATCH_SIZE=16
EMBEDDING_TIMEOUT_SECONDS=120

# Grounded generation. Ollama is called only by FastAPI after evidence retrieval.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=qwen2.5:7b-instruct
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=120
RETRIEVAL_MATCH_COUNT=8
MIN_EVIDENCE_SCORE=0.20
MAX_CONTEXT_TOKENS=1800
CHAT_RATE_LIMIT_PER_MINUTE=30

# This is intentionally public: the browser calls FastAPI, never Supabase.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
