# Required: server-side Supabase project credentials.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Default cloud LLM used for answer generation.
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
LLM_TEMPERATURE=0.1
LLM_MAX_OUTPUT_TOKENS=1024
LLM_TIMEOUT_SECONDS=120

# Embeddings remain local; the response model runs through DeepSeek API.
EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://127.0.0.1:11434
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSIONS=1024

# Source Wiki.
WIKI_BASE_URL=https://dontstarve.wiki.gg
WIKI_API_URL=https://dontstarve.wiki.gg/api.php
AUTO_INGEST_ENABLED=true
AUTO_INGEST_MAX_PAGES=3
